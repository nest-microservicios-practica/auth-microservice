PORT=3004

# Para NATS
# separamos por coma ya que las variables de entorno pueden ser arrays
# NATS_SERVERS='nats://localhost:4222,nats://localhost:4223'
NATS_SERVERS='nats://localhost:4222'

MONGO_DB=midb

# DATABASE_URL la lee Prisma a través de `prisma.config.ts` (que importa `dotenv/config`).
# Para ejecutar `prisma db push` / `prisma generate` desde tu HOST (fuera de Docker),
# debe apuntar a `localhost`. Dentro del contenedor `auth-microservice` esta variable se sobreescribe
# desde `docker-compose.yml` apuntando a `mongo-database:27017`.
# replicaSet=rs0 + directConnection=true son obligatorios porque Prisma requiere replica set en MongoDB.
DATABASE_URL=mongodb://localhost:27017/midb?replicaSet=rs0&directConnection=true


JWT_SECRET=mi_clave_secreta_para_jwt..